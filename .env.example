# Secret Network wallet mnemonic (used for submitting bridge transactions)
WALLET_KEY=your twenty four word secret network wallet mnemonic goes here

# Monero wallet mnemonic (25 words - REQUIRED to enable the bridge)
MONERO_MNEMONIC=your twenty five word monero wallet mnemonic goes here

# Monero wallet file encryption password (optional, default: bridge123)
MONERO_WALLET_PASSWORD=bridge123

# Monero restore height - set to a block height near when the wallet was created
# for faster initial sync. Current mainnet height is ~3.3M+
MONERO_RESTORE_HEIGHT=3300000

# Number of confirmations required before minting tokens (default: 20)
XMR_CONFIRMATION_THRESHOLD=20

# Remote Monero daemon host for wallet-rpc to connect to (default: node.moneroworld.com)
# MONERO_DAEMON_HOST=node.moneroworld.com

# Remote Monero daemon port (default: 18089)
# MONERO_DAEMON_PORT=18089

# Secret Network LCD endpoint (optional, default: https://lcd.erth.network)
# SECRET_LCD_URL=https://lcd.erth.network

# Secret Network chain ID (optional, default: secret-4)
# SECRET_CHAIN_ID=secret-4

# XMR SNIP-20 token contract on Secret Network (optional, defaults are set)
# XMR_TOKEN_CONTRACT=secret1uahwhw3rk2x8vx4963yxqw6nl8h9drk79kasfx
# XMR_TOKEN_HASH=83d3a35e92363d3ef743dec1e9f2e8b3a18f2c761fe44169f11b436648a21078

# XMR minter/bridge manager contract on Secret Network (optional, defaults are set)
# XMR_MINTER_CONTRACT=secret130nl6yfwuzjmnuknwfccq7jl8qekl4kcz0ppap
# XMR_MINTER_HASH=91bed2b7eac8ba8e29c89efc32fcf0d0d0352d75f945da9035bc2ac4fa1ac14d

# Monero wallet-rpc URL (optional, default: http://127.0.0.1:18083)
# Only change if running wallet-rpc externally
# MONERO_WALLET_RPC_URL=http://127.0.0.1:18083
